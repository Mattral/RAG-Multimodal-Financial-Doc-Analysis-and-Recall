{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}],
  "title": "RAG Financial — Quality & Cost",
  "uid": "rag-financial-quality",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "60s",
  "tags": ["rag", "financial", "quality", "cost"],
  "panels": [
    {
      "id": 1, "type": "gauge", "title": "Avg Faithfulness Score",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "1 - histogram_quantile(0.50, rate(rag_hallucination_score_bucket[1h]))", "legendFormat": "faithfulness"}],
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 0.7, "color": "yellow"}, {"value": 0.85, "color": "green"}]}}}
    },
    {
      "id": 2, "type": "gauge", "title": "Citation Coverage (avg)",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.50, rate(rag_citation_coverage_ratio_bucket[1h]))", "legendFormat": "citation coverage"}],
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "thresholds": {"steps": [{"value": 0, "color": "red"}, {"value": 0.6, "color": "yellow"}, {"value": 0.8, "color": "green"}]}}}
    },
    {
      "id": 3, "type": "stat", "title": "Cost Per Query (avg, USD)",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "rate(rag_query_cost_usd_total[1h]) / rate(rag_queries_total[1h])", "legendFormat": "$/query"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 5}}
    },
    {
      "id": 4, "type": "stat", "title": "Active Tenants",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "rag_active_tenants", "legendFormat": "tenants"}]
    },
    {
      "id": 5, "type": "timeseries", "title": "Hallucination Score Over Time (p50, p95)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(rag_hallucination_score_bucket[10m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(rag_hallucination_score_bucket[10m]))", "legendFormat": "p95"}
      ],
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}}}
    },
    {
      "id": 6, "type": "timeseries", "title": "Cumulative Cost by Tenant (USD)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [{"expr": "increase(rag_query_cost_usd_total[1h])", "legendFormat": "{{tenant_id}} / {{model}}"}]
    },
    {
      "id": 7, "type": "barchart", "title": "Token Usage by Model (last 24h)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "targets": [
        {"expr": "increase(rag_tokens_total{token_type='prompt'}[24h])", "legendFormat": "{{model}} prompt"},
        {"expr": "increase(rag_tokens_total{token_type='completion'}[24h])", "legendFormat": "{{model}} completion"}
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Cache Hit Rate (Embedding + Semantic)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "targets": [
        {"expr": "rate(rag_cache_hits_total{cache_type='embedding'}[5m])", "legendFormat": "embedding hits/s"},
        {"expr": "rate(rag_cache_hits_total{cache_type='semantic'}[5m])", "legendFormat": "semantic hits/s"}
      ]
    },
    {
      "id": 9, "type": "table", "title": "Per-Tenant Query Volume (last 1h)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "targets": [{"expr": "increase(rag_queries_total[1h])", "legendFormat": "{{tenant_id}}"}]
    },
    {
      "id": 10, "type": "timeseries", "title": "Chunks Returned per Query (p50, p95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(rag_retrieval_chunks_returned_bucket[5m]))", "legendFormat": "p50 chunks"},
        {"expr": "histogram_quantile(0.95, rate(rag_retrieval_chunks_returned_bucket[5m]))", "legendFormat": "p95 chunks"}
      ]
    }
  ]
}
